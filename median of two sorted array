class Solution {
    public double findMedianSortedArrays(int[] nums1, int[] nums2) {
        // Ensure nums1 is the smaller array to optimize binary search runtime to O(log(min(m, n)))
        if (nums1.length > nums2.length) {
            return findMedianSortedArrays(nums2, nums1);
        }
        
        int m = nums1.length;
        int n = nums2.length;
        
        int low = 0;
        int high = m;
        int totalLeft = (m + n + 1) / 2;
        
        while (low <= high) {
            // Partition index for nums1
            int i = low + (high - low) / 2;
            // Partition index for nums2
            int j = totalLeft - i;
            
            // Handle edge conditions when partition falls on the array boundaries
            int maxLeftA = (i == 0) ? Integer.MIN_VALUE : nums1[i - 1];
            int minRightA = (i == m) ? Integer.MAX_VALUE : nums1[i];
            
            int maxLeftB = (j == 0) ? Integer.MIN_VALUE : nums2[j - 1];
            int minRightB = (j == n) ? Integer.MAX_VALUE : nums2[j];
            
            // Correct partition found
            if (maxLeftA <= minRightB && maxLeftB <= minRightA) {
                // If total elements count is odd
                if ((m + n) % 2 != 0) {
                    return Math.max(maxLeftA, maxLeftB);
                }
                // If total elements count is even
                return (Math.max(maxLeftA, maxLeftB) + Math.min(minRightA, minRightB)) / 2.0;
            } 
            // We are too far right in nums1, shift partition to the left
            else if (maxLeftA > minRightB) {
                high = i - 1;
            } 
            // We are too far left in nums1, shift partition to the right
            else {
                low = i + 1;
            }
        }
        
        return 0.0;
    }
}
