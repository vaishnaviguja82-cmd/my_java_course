import java.util.HashMap;
import java.util.Map;

public class Solution {
    public int[] twoSum(int[] nums, int target) {
        // Hash map to store the number and its corresponding index
        Map<Integer, Integer> seen = new HashMap<>();
        
        for (int i = 0; i < nums.length; i++) {
            int complement = target - nums[i];
            
            // Check if the required complement is already in the map
            if (seen.containsKey(complement)) {
                return new int[] { seen.get(complement), i };
            }
            
            // Store the current number and index
            seen.put(nums[i], i);
        }
        
        // Return an empty array if no solution is found (per constraints, this won't be reached)
        return new int[] {};
    }
}
